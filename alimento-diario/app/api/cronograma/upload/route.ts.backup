// app/api/cronograma/upload/route.ts - Versão corrigida

import { NextRequest, NextResponse } from 'next/server';
import { writeFileSync } from 'fs';
import { join } from 'path';

const CRONOGRAMA_PATH = join(process.cwd(), 'data', 'cronograma.json');

export async function POST(request: NextRequest) {
    try {
        const formData = await request.formData();
        const file = formData.get('file') as File;

        if (!file) {
            return NextResponse.json({ erro: 'Nenhum arquivo enviado' }, { status: 400 });
        }

        if (file.type !== 'application/pdf') {
            return NextResponse.json({
                erro: 'Tipo de arquivo não suportado. Use apenas PDF.'
            }, { status: 400 });
        }

        const buffer = Buffer.from(await file.arrayBuffer());

        // Melhor tratamento de erro na extração
        let texto = '';
        try {
            texto = await extrairTextoPDF(buffer);
            console.log('Texto extraído (primeiro 500 chars):', texto.substring(0, 500));
        } catch (pdfError) {
            console.error('Erro ao extrair PDF:', pdfError);
            return NextResponse.json({
                erro: 'Erro ao processar PDF. Verifique se o arquivo não está corrompido.',
                detalhes: String(pdfError)
            }, { status: 400 });
        }

        // Parser do cronograma com logs melhorados
        const cronograma = parsearCronogramaTexto(texto);

        if (Object.keys(cronograma).length === 0) {
            return NextResponse.json({
                erro: 'Não foi possível extrair cronograma do arquivo. Verifique se o formato está correto.',
                textoExtraido: texto.substring(0, 1000),
                dica: 'O PDF deve conter referências bíblicas no formato: "Dia 1: Gênesis 1-2, Mateus 1, Salmo 1, Provérbios 1"'
            }, { status: 400 });
        }

        // Salvar cronograma personalizado
        const cronogramaData = {
            personalizado: true,
            leituras: cronograma,
            uploadedAt: new Date().toISOString(),
            tipoArquivo: 'pdf',
            nomeArquivo: file.name,
            totalDias: Object.keys(cronograma).length
        };

        writeFileSync(CRONOGRAMA_PATH, JSON.stringify(cronogramaData, null, 2));

        return NextResponse.json({
            sucesso: true,
            totalDias: Object.keys(cronograma).length,
            mensagem: 'Cronograma personalizado carregado com sucesso!',
            tipoProcessamento: 'PDF',
            primeirosDias: Object.fromEntries(
                Object.entries(cronograma).slice(0, 3) // Mostrar os 3 primeiros dias para debug
            )
        });

    } catch (error) {
        console.error('Erro geral ao processar arquivo:', error);
        return NextResponse.json(
            {
                erro: 'Erro interno ao processar PDF.',
                detalhes: String(error)
            },
            { status: 500 }
        );
    }
}

async function extrairTextoPDF(buffer: Buffer): Promise<string> {
    try {
        const pdfjs = await import('pdfjs-dist/legacy/build/pdf.mjs');

        console.log('Iniciando extração de PDF sem worker...');

        const loadingTask = pdfjs.getDocument({
            data: new Uint8Array(buffer),
            // Desabilitar worker explicitamente
            useWorkerFetch: false,
            isEvalSupported: false,
            // Configurações adicionais para evitar problemas no servidor
            verbosity: 0
        });

        const pdf = await loadingTask.promise;
        let textoCompleto = '';

        console.log(`PDF carregado com ${pdf.numPages} páginas`);

        for (let i = 1; i <= pdf.numPages; i++) {
            try {
                const page = await pdf.getPage(i);
                const textContent = await page.getTextContent();

                let paginaTexto = '';
                for (const item of textContent.items) {
                    if (item && 'str' in item && item.str.trim()) {
                        paginaTexto += item.str + ' ';
                    }
                }

                textoCompleto += paginaTexto + '\n';
                console.log(`Página ${i} processada: ${paginaTexto.length} caracteres`);
            } catch (pageError) {
                console.error(`Erro ao processar página ${i}:`, pageError);
                continue;
            }
        }

        console.log(`Extração concluída: ${textoCompleto.length} caracteres totais`);

        if (!textoCompleto.trim()) {
            throw new Error('Nenhum texto foi extraído do PDF');
        }

        return textoCompleto;
    } catch (error) {
        console.error('Erro ao processar PDF:', error);
        throw new Error(`Falha ao extrair texto do PDF: ${error}`);
    }
}

// Parser melhorado com mais padrões e logging
function parsearCronogramaTexto(texto: string) {
    const cronograma: Record<number, any> = {};

    // Normalizar texto
    const textoLimpo = texto
        .replace(/\s+/g, ' ')
        .replace(/[^\w\sÀ-ÿ\d\-:.,;()]/g, '')
        .trim();

    console.log('=== INICIANDO PARSER ===');
    console.log('Texto a processar:', textoLimpo.length, 'caracteres');

    // Dividir em linhas/seções
    const linhas = textoLimpo.split(/[.\n;]/).filter(l => l.trim().length > 3);
    console.log('Linhas encontradas:', linhas.length);

    let diaAtual = 0;

    for (let i = 0; i < linhas.length; i++) {
        const linha = linhas[i].trim();
        if (!linha) continue;

        // Padrões mais robustos para detectar dias
        const padroesDia = [
            /\b(?:dia|day)\s*(\d+)\b/i,
            /^(\d+)[\s\-:\.]\s*/,
            /(\d+)º?\s*dia/i,
            /^\s*(\d+)\s*[\-:]\s*/
        ];

        let diaEncontrado = 0;
        for (const padrao of padroesDia) {
            const match = linha.match(padrao);
            if (match) {
                const num = parseInt(match[1]);
                if (num >= 1 && num <= 365) {
                    diaEncontrado = num;
                    break;
                }
            }
        }

        if (diaEncontrado > 0) {
            diaAtual = diaEncontrado;
            console.log(`>>> Dia ${diaAtual} detectado na linha: ${linha.substring(0, 50)}...`);
        }

        // Se não encontrou dia específico, incrementar automaticamente
        if (diaAtual === 0) {
            diaAtual = 1;
        }

        // Buscar referências bíblicas na linha
        const referencias = extrairReferenciasMelhorado(linha);

        if (referencias.length > 0 && diaAtual <= 365) {
            if (!cronograma[diaAtual]) {
                cronograma[diaAtual] = {
                    at: "",
                    nt: "",
                    salmo: "",
                    proverbios: ""
                };
            }

            // Classificar referências com lógica melhorada
            let temConteudo = false;
            referencias.forEach(ref => {
                const refLower = ref.toLowerCase();

                if (refLower.includes('salmo') || refLower.includes('sl ')) {
                    if (!cronograma[diaAtual].salmo) {
                        cronograma[diaAtual].salmo = ref;
                        temConteudo = true;
                    }
                } else if (refLower.includes('provérb') || refLower.includes('pv ')) {
                    if (!cronograma[diaAtual].proverbios) {
                        cronograma[diaAtual].proverbios = ref;
                        temConteudo = true;
                    }
                } else if (isAntigoTestamento(ref)) {
                    if (!cronograma[diaAtual].at) {
                        cronograma[diaAtual].at = ref;
                        temConteudo = true;
                    }
                } else if (isNovoTestamento(ref)) {
                    if (!cronograma[diaAtual].nt) {
                        cronograma[diaAtual].nt = ref;
                        temConteudo = true;
                    }
                }
            });

            if (temConteudo) {
                console.log(`Dia ${diaAtual} preenchido:`, cronograma[diaAtual]);

                // Avançar para o próximo dia se este estiver bem preenchido
                if (cronograma[diaAtual].at && cronograma[diaAtual].nt) {
                    diaAtual++;
                }
            }
        }
    }

    console.log('=== RESULTADO FINAL ===');
    console.log(`Cronograma processado: ${Object.keys(cronograma).length} dias`);
    console.log('Primeiros 3 dias:', Object.fromEntries(Object.entries(cronograma).slice(0, 3)));

    return cronograma;
}

// Extração melhorada de referências
function extrairReferenciasMelhorado(texto: string): string[] {
    const referencias: string[] = [];

    // Padrões mais específicos e organizados
    const padroes = [
        // Livros com números (1 Samuel, 2 Reis, etc)
        /\b([12]\s*(?:Samuel|Sm|Reis|Re|Crônicas|Cr|Coríntios|Co|Tessalonicenses|Ts|Timóteo|Tm|Pedro|Pe))\s+(\d+)(?:[-:\s]*(\d+))?(?:[-:\s]*(\d+))?\b/gi,

        // Salmos específico
        /\b(Salmos?)\s+(\d+)(?:[-:\s]*(\d+))?(?:[-:\s]*(\d+))?\b/gi,

        // Provérbios específico  
        /\b(Provérb[íi]os?)\s+(\d+)(?:[-:\s]*(\d+))?(?:[-:\s]*(\d+))?\b/gi,

        // Livros normais
        /\b([A-Za-zÀ-ÿ]+)\s+(\d+)(?:[-:\s]*(\d+))?(?:[-:\s]*(\d+))?\b/g,

        // Abreviações comuns
        /\b(Gn|Ex|Lv|Nm|Dt|Js|Jz|Rt|1Sm|2Sm|1Rs|2Rs|Mt|Mc|Lc|Jo|At|Rm|1Co|2Co|Gl|Ef|Fp|Cl|1Ts|2Ts|1Tm|2Tm|Tt|Fm|Hb|Tg|1Pe|2Pe|1Jo|2Jo|3Jo|Jd|Ap)\s+(\d+)(?:[-:\s]*(\d+))?(?:[-:\s]*(\d+))?\b/gi
    ];

    padroes.forEach(padrao => {
        let match;
        while ((match = padrao.exec(texto)) !== null) {
            const ref = match[0].trim();
            if (ref.length > 2 && !referencias.some(r => r.toLowerCase().includes(ref.toLowerCase()))) {
                referencias.push(ref);
            }
        }
    });

    return [...new Set(referencias)]; // Remover duplicatas
}

// Funções auxiliares melhoradas
function isAntigoTestamento(referencia: string): boolean {
    const livrosAT = [
        'gênesis', 'genesis', 'gn',
        'êxodo', 'exodo', 'ex',
        'levítico', 'levitico', 'lv',
        'números', 'numeros', 'nm',
        'deuteronômio', 'deuteronomio', 'dt',
        'josué', 'josue', 'js',
        'juízes', 'juizes', 'jz',
        'rute', 'rt',
        'samuel', 'sm', '1sm', '2sm',
        'reis', 're', '1rs', '2rs',
        'crônicas', 'cronicas', 'cr', '1cr', '2cr',
        'esdras', 'ed',
        'neemias', 'ne',
        'ester', 'et',
        'jó', 'job',
        'salmo', 'sl',
        'provérb', 'proverb', 'pv',
        'eclesiastes', 'ec',
        'cantares', 'ct',
        'isaías', 'isaias', 'is',
        'jeremias', 'jr',
        'lamentações', 'lamentacoes', 'lm',
        'ezequiel', 'ez',
        'daniel', 'dn',
        'oséias', 'oseias', 'os'
    ];
    return livrosAT.some(livro => referencia.toLowerCase().includes(livro));
}

function isNovoTestamento(referencia: string): boolean {
    const livrosNT = [
        'mateus', 'mt',
        'marcos', 'mc',
        'lucas', 'lc',
        'joão', 'joao', 'jo',
        'atos', 'at',
        'romanos', 'rm',
        'coríntios', 'corintios', 'co', '1co', '2co',
        'gálatas', 'galatas', 'gl',
        'efésios', 'efesios', 'ef',
        'filipenses', 'fp',
        'colossenses', 'cl',
        'tessalonicenses', 'ts', '1ts', '2ts',
        'timóteo', 'timoteo', 'tm', '1tm', '2tm',
        'tito', 'tt',
        'filemom', 'fm',
        'hebreus', 'hb',
        'tiago', 'tg',
        'pedro', 'pe', '1pe', '2pe',
        'joão', 'jo', '1jo', '2jo', '3jo',
        'judas', 'jd',
        'apocalipse', 'ap'
    ];
    return livrosNT.some(livro => referencia.toLowerCase().includes(livro));
}